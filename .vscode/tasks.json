{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build playground",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Playground/Cerneala.Playground/Cerneala.Playground.csproj"
      ],
      "options": {
        "env": {
          "MSBuildEnableWorkloadResolver": "false"
        }
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build cerneala presentation",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/CernealaPresentation/CernealaPresentation.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "MSBuildEnableWorkloadResolver": "false"
        }
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    }
  ]
}
