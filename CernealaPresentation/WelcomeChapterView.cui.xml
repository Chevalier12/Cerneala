<UserControl
    Aspect="$PageReveal">
    <Grid>
        <StackPanel
            Margin="46,38,46,42">
            <TextBlock
                Text="01 / ORIENTATION"
                FontFamily="Cascadia Mono SemiBold"
                FontSize="11"
                Foreground="$CyanBrush" />
            <TextBlock
                Text="UI that thinks in frames."
                FontFamily="Bahnschrift SemiBold"
                FontSize="52"
                Foreground="$PaperBrush"
                Margin="0,12,0,0" />
            <TextBlock
                Text="Cerneala is a retained C# UI framework shaped for MonoGame: typed properties, logical and visual trees, templated controls, dirty queues, native Windows hosting, and backend-neutral drawing."
                FontSize="17"
                Foreground="$SlateBrush"
                TextWrapping="Wrap"
                Margin="0,16,80,0" />
            <Grid
                Margin="0,34,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="1.15*" />
                    <ColumnDefinition
                        Width="0.85*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Background="$PanelBrush"
                    BorderBrush="$LineStrongBrush"
                    BorderThickness="1"
                    Padding="24"
                    Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock
                            Text="THE MENTAL MODEL"
                            FontFamily="Cascadia Mono SemiBold"
                            FontSize="10"
                            Foreground="$PinkBrush" />
                        <TextBlock
                            Text="Describe the tree. Mutate typed state. Let the frame scheduler do only the work that became dirty."
                            FontFamily="Bahnschrift"
                            FontSize="23"
                            Foreground="$PaperBrush"
                            TextWrapping="Wrap"
                            Margin="0,14,0,0" />
                        <Border
                            Background="$PanelAltBrush"
                            BorderBrush="$LineBrush"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,22,0,0">
                            <TextBlock
                                Text="input  ->  state  ->  measure  ->  arrange  ->  cache  ->  draw"
                                FontFamily="Cascadia Mono"
                                FontSize="12"
                                Foreground="$LimeBrush"
                                TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
                <StackPanel
                    Grid.Column="1"
                    Margin="14,0,0,0">
                    <Border
                        Background="$CyanWashBrush"
                        BorderBrush="$CyanBrush"
                        BorderThickness="2,0,0,0"
                        Padding="18,14,18,14"
                        Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock
                                Text="RETAINED"
                                FontFamily="Cascadia Mono SemiBold"
                                FontSize="11"
                                Foreground="$CyanBrush" />
                            <TextBlock
                                Text="The tree survives every frame."
                                FontSize="13"
                                Foreground="$SlateBrush"
                                Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                    <Border
                        Background="$LimeWashBrush"
                        BorderBrush="$LimeBrush"
                        BorderThickness="2,0,0,0"
                        Padding="18,14,18,14"
                        Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock
                                Text="TYPED"
                                FontFamily="Cascadia Mono SemiBold"
                                FontSize="11"
                                Foreground="$LimeBrush" />
                            <TextBlock
                                Text="Properties carry contracts and effects."
                                FontSize="13"
                                Foreground="$SlateBrush"
                                Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                    <Border
                        Background="$PinkWashBrush"
                        BorderBrush="$PinkBrush"
                        BorderThickness="2,0,0,0"
                        Padding="18,14,18,14">
                        <StackPanel>
                            <TextBlock
                                Text="OBSERVABLE"
                                FontFamily="Cascadia Mono SemiBold"
                                FontSize="11"
                                Foreground="$PinkBrush" />
                            <TextBlock
                                Text="Diagnostics explain what changed."
                                FontSize="13"
                                Foreground="$SlateBrush"
                                Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
