                    <Ellipse
                        Width="27"
                        Height="27"
                        Fill="$SolarWarmBrush"
                        Opacity="0.46"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                    <Ellipse
                        Width="18"
                        Height="18"
                        Fill="$SolarSunBrush"
                        Stroke="$SolarWarmBrush"
