                    </Grid>

                    <Grid Name="MercuryOrbit" Width="87" Height="87" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid Name="MercuryBody" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Center" MouseUp="OnMercuryClicked">
                            <Ellipse Width="36" Height="36" Fill="$SolarTransparentBrush" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Fill="$MercuryGradient" Stroke="$SolarTextBrush" StrokeThickness="1" />
