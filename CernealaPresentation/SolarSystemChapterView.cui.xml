<UserControl
    Aspect="$SolarMotion"
    FontFamily="Segoe UI"
    FontSize="12"
    Foreground="$SolarTextBrush"
    Background="$SolarSpaceBrush"
    ClipToBounds="True"
    MouseWheel="OnMouseWheel">
    <UserControl.Resources>
        <SolidColorBrush
            Name="SolarSpaceBrush"
            Color="#FF02040A" />
        <SolidColorBrush
            Name="SolarPanelBrush"
            Color="#D0070C16" />
        <SolidColorBrush
            Name="SolarPanelStrongBrush"
            Color="#EB080E1A" />
        <SolidColorBrush
            Name="SolarLineBrush"
            Color="#3AB1CCE6" />
        <SolidColorBrush
            Name="SolarTextBrush"
            Color="#FFEDF6FF" />
        <SolidColorBrush
            Name="SolarMutedBrush"
            Color="#FF9DB0C5" />
        <SolidColorBrush
            Name="SolarAccentBrush"
            Color="#FF7DD3FC" />
        <SolidColorBrush
            Name="SolarWarmBrush"
            Color="#FFFFB84D" />
        <SolidColorBrush
            Name="SolarSunBrush"
            Color="#FFFFAD42" />
        <SolidColorBrush
            Name="SolarTransparentBrush"
            Color="#00000000" />
        <RadialGradientBrush
            Name="SolarSpaceGradient"
            Center="510,330"
            RadiusX="820"
            RadiusY="680">
            <GradientStop
                Offset="0"
                Color="#FF0B1424" />
            <GradientStop
                Offset="0.44"
                Color="#FF050B15" />
            <GradientStop
                Offset="1"
                Color="#FF010207" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="SunSurfaceGradient"
            Center="18,16"
            RadiusX="34"
            RadiusY="34">
            <GradientStop
                Offset="0"
                Color="#FFFFF9C7" />
            <GradientStop
                Offset="0.22"
                Color="#FFFFD46B" />
            <GradientStop
                Offset="0.64"
                Color="#FFFF912F" />
            <GradientStop
                Offset="1"
                Color="#FFD95118" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="MercuryGradient"
            Center="3,3"
            RadiusX="7"
            RadiusY="7">
            <GradientStop
                Offset="0"
                Color="#FFD9D2C7" />
            <GradientStop
                Offset="0.55"
                Color="#FF89837C" />
            <GradientStop
                Offset="1"
                Color="#FF3F4144" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="VenusGradient"
            Center="4,4"
            RadiusX="10"
            RadiusY="10">
            <GradientStop
                Offset="0"
                Color="#FFFFE1A1" />
            <GradientStop
                Offset="0.55"
                Color="#FFC78A44" />
            <GradientStop
                Offset="1"
                Color="#FF613B27" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="EarthGradient"
            Center="4,4"
            RadiusX="11"
            RadiusY="11">
            <GradientStop
                Offset="0"
                Color="#FF8CD6FF" />
            <GradientStop
                Offset="0.55"
                Color="#FF246FB8" />
            <GradientStop
                Offset="1"
                Color="#FF071C42" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="MarsGradient"
            Center="3,3"
            RadiusX="8"
            RadiusY="8">
            <GradientStop
                Offset="0"
                Color="#FFF49A68" />
            <GradientStop
                Offset="0.55"
                Color="#FFAE492F" />
            <GradientStop
                Offset="1"
                Color="#FF401B1B" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="JupiterGradient"
            Center="9,8"
            RadiusX="24"
            RadiusY="24">
            <GradientStop
                Offset="0"
                Color="#FFF3D8B3" />
            <GradientStop
                Offset="0.55"
                Color="#FFB77955" />
            <GradientStop
                Offset="1"
                Color="#FF59423D" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="SaturnGradient"
            Center="8,7"
            RadiusX="21"
            RadiusY="21">
            <GradientStop
                Offset="0"
                Color="#FFF6E2AA" />
            <GradientStop
                Offset="0.55"
                Color="#FFC09E63" />
            <GradientStop
                Offset="1"
                Color="#FF554837" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="UranusGradient"
            Center="6,5"
            RadiusX="15"
            RadiusY="15">
            <GradientStop
                Offset="0"
                Color="#FFC6FBF7" />
            <GradientStop
                Offset="0.55"
                Color="#FF67B8C7" />
            <GradientStop
                Offset="1"
                Color="#FF24566D" />
        </RadialGradientBrush>
        <RadialGradientBrush
            Name="NeptuneGradient"
            Center="6,5"
            RadiusX="15"
            RadiusY="15">
            <GradientStop
                Offset="0"
                Color="#FF86A9FF" />
            <GradientStop
                Offset="0.55"
                Color="#FF3157BD" />
            <GradientStop
                Offset="1"
                Color="#FF102152" />
        </RadialGradientBrush>
        <PrismComposition
            Name="PlanetCardPrism">
            @group CardTreatment
            {
                Opacity = 1;
                BlendMode = Normal;

                @layer CardClarity
                {
                    @filter BrightnessContrast
                    {
                        Brightness = 0.02;
                        Contrast = 0.08;
                    }
                }
            }

            @backdrop SpaceGlass
            {
                Opacity = 0.76;

                @filter Blur
                {
                    Radius = 8;
                }
            }
        </PrismComposition>
        <PrismComposition
            Name="PlanetCardPulsePrism">
            @layer SignalPulse
            {
                @parameter GlowOpacity: float = 0.35;
                Opacity = 1;
                BlendMode = Screen;

                @style OuterGlow
                {
                    Size = 24;
                    Opacity = GlowOpacity;
                    Color = #37fb01;
                }
            }
        </PrismComposition>
        <MotionClip
            Name="PlanetCardPulse"
            TargetType="Cerneala.Presentation.SolarSystemChapterView">
            @animate with PingPong(Tween(3s, EaseInOut), forever)
            {
                @from { $PlanetInfoPulseFrame.prism.SignalPulse.GlowOpacity = 0.35; }
                @to { $PlanetInfoPulseFrame.prism.SignalPulse.GlowOpacity = 1.00; }
            }
        </MotionClip>
        <MotionClip
            Name="SolarCycle"
            TargetType="Cerneala.Presentation.SolarSystemChapterView">
            @parallel
            {
                @animate with Repeat(Tween(7s, Linear), forever)
                {
                    @from { $MercuryOrbit.Rotation = 1.1; $MercuryBody.Rotation = -1.1; }
                    @to { $MercuryOrbit.Rotation = 7.383185; $MercuryBody.Rotation = -7.383185; }
                }
                @animate with Repeat(Tween(9.2s, Linear), forever)
                {
                    @from { $VenusOrbit.Rotation = 2.8; $VenusBody.Rotation = -2.8; }
                    @to { $VenusOrbit.Rotation = 9.083185; $VenusBody.Rotation = -9.083185; }
                }
                @animate with Repeat(Tween(11.6s, Linear), forever)
                {
                    @from { $EarthOrbit.Rotation = 5.1; $EarthBody.Rotation = -5.1; }
                    @to { $EarthOrbit.Rotation = 11.383185; $EarthBody.Rotation = -11.383185; }
                }
                @animate with Repeat(Tween(14.6s, Linear), forever)
                {
                    @from { $MarsOrbit.Rotation = 3.9; $MarsBody.Rotation = -3.9; }
                    @to { $MarsOrbit.Rotation = 10.183185; $MarsBody.Rotation = -10.183185; }
                }
                @animate with Repeat(Tween(42s, Linear), forever)
                {
                    @from { $AsteroidBelt.Rotation = 0; }
                    @to { $AsteroidBelt.Rotation = 6.283185; }
                }
                @animate with Repeat(Tween(26s, Linear), forever)
                {
                    @from { $JupiterOrbit.Rotation = 0.5; $JupiterBody.Rotation = -0.5; }
                    @to { $JupiterOrbit.Rotation = 6.783185; $JupiterBody.Rotation = -6.783185; }
                }
                @animate with Repeat(Tween(37s, Linear), forever)
                {
                    @from { $SaturnOrbit.Rotation = 2; $SaturnBody.Rotation = -2; }
                    @to { $SaturnOrbit.Rotation = 8.283185; $SaturnBody.Rotation = -8.283185; }
                }
                @animate with Repeat(Tween(52s, Linear), forever)
                {
                    @from { $UranusOrbit.Rotation = 4.4; $UranusBody.Rotation = -4.4; }
                    @to { $UranusOrbit.Rotation = 10.683185; $UranusBody.Rotation = -10.683185; }
                }
                @animate with Repeat(Tween(66s, Linear), forever)
                {
                    @from { $NeptuneOrbit.Rotation = 5.8; $NeptuneBody.Rotation = -5.8; }
                    @to { $NeptuneOrbit.Rotation = 12.083185; $NeptuneBody.Rotation = -12.083185; }
                }
                @animate with Repeat(Tween(13s, Linear), forever)
                {
                    @from { $Comet.TranslateX = 430; $Comet.TranslateY = -210; }
                    @to { $Comet.TranslateX = -760; $Comet.TranslateY = 260; }
                }
            }
        </MotionClip>
        <Aspect
            Name="SolarMotion"
            TargetType="Cerneala.Presentation.SolarSystemChapterView">
            @handle SolarOrbits;
            @handle PlanetCardEffect;
            @when $self.Visibility
            {
                @if value == Visible
                {
                    @run $SolarCycle as SolarOrbits;
                }
                @if value == Collapsed
                {
                    @cancel SolarOrbits;
                }
            }
            @when $self.Visibility
            {
                @if value == Visible
                {
                    @run $PlanetCardPulse as PlanetCardEffect;
                }
                @if value == Collapsed
                {
                    @cancel PlanetCardEffect;
                }
            }
        </Aspect>
    </UserControl.Resources>

    <Grid
