                    </StackPanel>
                </StackPanel>

                <Grid
                    Grid.Row="1"
                    Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition
                            Width="*" />
                        <ColumnDefinition
                            Width="*" />
                        <ColumnDefinition
                            Width="*" />
