                        <Ellipse Width="1" Height="1" Fill="$SolarMutedBrush" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="82,0,0,0" />
                        <Ellipse Width="3" Height="3" Fill="$SolarTextBrush" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,12,2" />
                        <Ellipse Width="2" Height="2" Fill="$SolarMutedBrush" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="62,0,0,10" />
                        <Ellipse Width="1" Height="1" Fill="$SolarTextBrush" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="28,0,0,38" />
                        <Ellipse Width="3" Height="3" Fill="$SolarLineBrush" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,72" />
