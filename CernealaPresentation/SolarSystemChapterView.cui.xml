                            <TextBlock Text="Jupiter" Width="54" FontSize="9" Foreground="$SolarMutedBrush" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="-12,35,-12,0" />
                        </Grid>
                    </Grid>
                    <Grid Name="SaturnOrbit" Width="453" Height="453" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid Name="SaturnBody" Width="46" Height="28" HorizontalAlignment="Right" VerticalAlignment="Center" MouseUp="OnSaturnClicked">
                            <Ellipse Width="60" Height="60" Fill="$SolarTransparentBrush" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Width="44" Height="12" Stroke="#DDE8D39E" StrokeThickness="3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Width="25" Height="25" Fill="$SaturnGradient" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border Width="21" Height="2" Background="#448C704C" VerticalAlignment="Center" Margin="0,5,0,0" />
                            <TextBlock Text="Saturn" Width="50" FontSize="9" Foreground="$SolarMutedBrush" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="-2,34,-2,0" />
                        </Grid>
                    </Grid>
                    <Grid Name="UranusOrbit" Width="549" Height="549" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid Name="UranusBody" Width="19" Height="19" HorizontalAlignment="Right" VerticalAlignment="Center" MouseUp="OnUranusClicked">
                            <Ellipse Width="36" Height="36" Fill="$SolarTransparentBrush" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Fill="$UranusGradient" Stroke="$SolarAccentBrush" StrokeThickness="1" />
                            <Ellipse Width="22" Height="7" Stroke="#668DE6E0" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="Uranus" Width="50" FontSize="9" Foreground="$SolarMutedBrush" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="-15,24,-15,0" />
                        </Grid>
                    </Grid>
                    <Grid Name="NeptuneOrbit" Width="645" Height="645" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid Name="NeptuneBody" Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Center" MouseUp="OnNeptuneClicked">
                            <Ellipse Width="36" Height="36" Fill="$SolarTransparentBrush" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Fill="$NeptuneGradient" Stroke="#AA86A9FF" StrokeThickness="1" />
                            <Border Width="12" Height="2" Background="#6686A9FF" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <TextBlock Text="Neptun" Width="50" FontSize="9" Foreground="$SolarMutedBrush" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="-16,23,-16,0" />
                        </Grid>
                    </Grid>

                    <Grid Name="SunBody" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Fill="$SunSurfaceGradient" Stroke="#FFFFC977" StrokeThickness="1" />
                        <Ellipse Width="8" Height="8" Fill="#44FFF09A" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12,9,0,0" />
                        <Ellipse Width="5" Height="5" Fill="#33FFF09A" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,9,0" />
                        <Ellipse Width="7" Height="7" Fill="#33FFF09A" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="9,0,0,11" />
                        <Ellipse Width="4" Height="4" Fill="#44FFF09A" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,13,8" />
                        <TextBlock Text="Soare" Width="46" FontFamily="Segoe UI Semibold" FontSize="10" Foreground="$SolarWarmBrush" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,57,0,0" />
                    </Grid>
                </Grid>

                <Grid
                    Name="Comet"
                    Width="116"
                    Height="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border Width="104" Height="1" Background="$SolarAccentBrush" Opacity="0.32" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    <Ellipse Width="14" Height="14" Fill="$SolarAccentBrush" Opacity="0.12" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <Ellipse Width="5" Height="5" Fill="$SolarTextBrush" Stroke="$SolarAccentBrush" StrokeThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>

        <Grid
            Grid.Row="0"
