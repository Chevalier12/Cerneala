                    <Ellipse Width="2" Height="2" Fill="$SolarTextBrush" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,40,94,0" />
                    <Ellipse Width="1" Height="1" Fill="$SolarAccentBrush" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,38,176" />
                    <Ellipse Width="2" Height="2" Fill="$SolarTextBrush" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="48,0,0,44" />
                    <Ellipse Width="1" Height="1" Fill="$SolarTextBrush" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="108,0,0,126" />
                    <Ellipse Width="2" Height="2" Fill="$SolarAccentBrush" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="168,0,0,72" />
