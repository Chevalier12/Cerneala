                </Grid>
                </Grid>
            </Border>

            <Border
                Name="PlanetInfoPulseFrame"
                BorderBrush="$SolarAccentBrush"
                BorderThickness="1">
                @prism $PlanetCardPulsePrism;
            </Border>
        </Grid>

        <TextBlock
            Grid.Row="1"
            Text="Trage pentru deplasare / rotita pentru zoom / click pe o planeta"
            FontSize="10"
            Foreground="$SolarMutedBrush"
            Opacity="0.58"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,22,12" />

    </Grid>
