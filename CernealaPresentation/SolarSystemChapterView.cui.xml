                        Padding="8,9,8,9">
                        <StackPanel>
                            <TextBlock
                                Text="DISTANTA"
                                FontSize="10"
                                Foreground="$SolarMutedBrush" />
                            <TextBlock
                                Name="DistanceText"
                                Text="149,6 mil. km"
                                FontFamily="Segoe UI Semibold"
                                FontSize="11"
                                Foreground="$SolarTextBrush"
                                TextWrapping="Wrap"
                                Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Column="1"
                        Background="$SolarPanelStrongBrush"
