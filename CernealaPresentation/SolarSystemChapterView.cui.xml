                        </Grid>
                    </Grid>
                    <Grid Name="JupiterOrbit" Width="348" Height="348" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid Name="JupiterBody" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center" MouseUp="OnJupiterClicked">
                            <Ellipse Width="44" Height="44" Fill="$SolarTransparentBrush" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Fill="$JupiterGradient" />
