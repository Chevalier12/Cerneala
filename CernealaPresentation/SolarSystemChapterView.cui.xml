                    <Ellipse Width="2" Height="2" Fill="$SolarAccentBrush" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,126,338,0" />
                    <Ellipse Width="1" Height="1" Fill="$SolarTextBrush" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,274,204" />
