                        <Ellipse Width="1" Height="1" Fill="$SolarTextBrush" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,2,98" />
                        <Ellipse Width="3" Height="3" Fill="$SolarMutedBrush" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,28" />
                        <Ellipse Width="2" Height="2" Fill="$SolarTextBrush" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,46,4,0" />
                        <Ellipse Width="1" Height="1" Fill="$SolarMutedBrush" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,62" />
