                <Grid.RowDefinitions>
                    <RowDefinition
                        Height="47" />
                    <RowDefinition
                        Height="*" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal">
                    <Grid
                        Width="31"
                        Height="31"
                        Margin="0,0,11,0">
                        <Ellipse
                            Name="PlanetSwatchGlow"
                            Width="31"
                            Height="31"
                            Fill="$SolarAccentBrush"
                            Opacity="0.18" />
                        <Ellipse
                            Name="PlanetSwatchCore"
                            Width="27"
                            Height="27"
                            Fill="$SolarAccentBrush"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel>
                        <TextBlock
                            Name="ObjectNameText"
                            Text="Pamant"
                            FontFamily="Segoe UI Semibold"
                            FontSize="19"
                            Foreground="$SolarTextBrush" />
                        <TextBlock
                            Name="ObjectTypeText"
                            Text="Planeta terestra"
                            FontSize="12"
                            Foreground="$SolarMutedBrush"
