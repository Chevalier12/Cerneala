<Window
    Title="Cerneala / Inside the Frame"
    Width="1320"
    Height="860"
    MinWidth="1080"
    MinHeight="720"
    WindowStartupLocation="CenterScreen"
    ContentRendered="OnContentRendered"
    FrameRendered="OnFrameRendered"
    Background="#FF0A0B0E"
    BorderBrush="#FF2A2E38"
    BorderThickness="1"
    Padding="0">
    <Window.Resources>
        <Tween
            Name="NavHoverIn"
            Duration="180ms"
            Easing="EaseOut" />
        <Tween
            Name="NavHoverOut"
            Duration="150ms"
            Easing="EaseIn" />
        <Tween
            Name="NavTextHover"
            Duration="150ms"
            Easing="EaseOut" />
        <Aspect
            Name="NavButton"
            Target="ToggleButton">
            @default
            {
                FontFamily = "Cascadia Mono SemiBold";
                FontSize = 12;
                Background = $TransparentBrush;
                Foreground = $SlateBrush;
                BorderBrush = $TransparentBrush;
                BorderThickness = "0";
                Padding = "18,10,12,10";
            }
            @when IsChecked
            {
                Background = $CyanWashBrush;
                Foreground = $PaperBrush;
                BorderBrush = $LimeBrush;
            }
            @when IsMouseOver
            {
                @if IsMouseOver == true
                {
                    @parallel
                    {
                        @animate with $NavHoverIn
                        {
                            @from
                            {
                                Background = current;
                                $self.parts.$PART_HoverLine.ScaleX = current;
                            }
                            @to
                            {
                                Background = $CyanWashBrush;
                                $self.parts.$PART_HoverLine.ScaleX = 1;
                            }
                        }
                        @animate with $NavTextHover
                        {
                            @from
                            {
                                Foreground = current;
                                $self.parts.$PART_HoverText.Opacity = current;
                            }
                            @to
                            {
                                Foreground = $PaperBrush;
                                $self.parts.$PART_HoverText.Opacity = 1;
                            }
                        }
                    }
                }
                @if IsMouseOver == false
                {
                    @parallel
                    {
                        @animate with $NavHoverOut
                        {
                            @from
                            {
                                Background = current;
                                $self.parts.$PART_HoverLine.ScaleX = current;
                            }
                            @to
                            {
                                Background = $TransparentBrush;
                                $self.parts.$PART_HoverLine.ScaleX = 0;
                            }
                        }
                        @animate with $NavTextHover
                        {
                            @from
                            {
                                Foreground = current;
                                $self.parts.$PART_HoverText.Opacity = current;
                            }
                            @to
                            {
                                Foreground = $SlateBrush;
                                $self.parts.$PART_HoverText.Opacity = 0;
                            }
                        }
                    }
                }
            }
            @template
            {
            <Grid
                ClipToBounds="True">
                <Border
                    Background="$owner.Background"
                    Padding="$owner.Padding">
                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">
                        <Grid>
                            <ContentPresenter
                                Content="$owner.Content"
                                FontFamily="$owner.FontFamily"
                                FontSize="$owner.FontSize"
                                Foreground="$owner.Foreground"
                                Margin="0,0,0,5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center" />
                            <ContentPresenter
                                Name="PART_HoverText"
                                Content="$owner.Content"
                                FontFamily="$owner.FontFamily"
                                FontSize="$owner.FontSize"
                                Foreground="$PaperBrush"
                                Opacity="0"
                                Margin="0,0,0,5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center" />
                            <Border
                                Name="PART_HoverLine"
                                Height="1"
                                Background="$CyanBrush"
                                ScaleX="0"
                                RenderTransformOrigin="0,0.5"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom" />
                        </Grid>
                    </StackPanel>
                </Border>
                <Border
                    Width="3"
                    Height="18"
                    Background="$owner.BorderBrush"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center" />
            </Grid>
            }
        </Aspect>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="68" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="66" />
        </Grid.RowDefinitions>
        <Border
            Grid.Row="0"
            Background="$PanelAltBrush"
            BorderBrush="$LineBrush"
            BorderThickness="0,0,0,1"
            Padding="26,0,26,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="250" />
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>
                <BrandMark
                    Grid.Column="0"
                    VerticalAlignment="Center" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <TextBlock
                        Text="/"
                        FontFamily="Cascadia Mono"
                        FontSize="13"
                        Foreground="$SlateDimBrush"
                        Margin="0,0,12,0" />
                    <TextBlock
                        Name="HeaderChapterText"
                        Text="WELCOME"
                        FontFamily="Cascadia Mono SemiBold"
                        FontSize="12"
                        Foreground="$CyanBrush" />
                </StackPanel>
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <TextBlock
                        Text="LIVE RETAINED TREE"
                        FontFamily="Cascadia Mono"
                        FontSize="10"
                        Foreground="$SlateBrush" />
                </StackPanel>
            </Grid>
        </Border>
        <Grid
            Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="250" />
                <ColumnDefinition
                    Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                Background="$PanelAltBrush"
                BorderBrush="$LineBrush"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition
                            Height="Auto" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Text="THE TOUR"
                        FontFamily="Cascadia Mono SemiBold"
                        FontSize="10"
                        Foreground="$SlateDimBrush"
                        Margin="20,22,0,12" />
                    <StackPanel
                        Grid.Row="1">
                        <ToggleButton
                            Name="NavWelcome"
                            Aspect="$NavButton"
                            Content="01  WELCOME"
                            Click="OnWelcome" />
                        <ToggleButton
                            Name="NavRetained"
                            Aspect="$NavButton"
                            Content="02  RETAINED MODEL"
                            Click="OnRetained" />
                        <ToggleButton
                            Name="NavMarkup"
                            Aspect="$NavButton"
                            Content="03  MARKUP"
                            Click="OnMarkup" />
                        <ToggleButton
                            Name="NavAspect"
                            Aspect="$NavButton"
                            Content="04  ASPECT"
                            Click="OnAspect" />
                        <ToggleButton
                            Name="NavMotion"
                            Aspect="$NavButton"
                            Content="05  MOTION"
                            Click="OnMotion" />
                        <ToggleButton
                            Name="NavSolarSystem"
                            Aspect="$NavButton"
                            Content="06  SOLAR MOTION"
                            Click="OnSolarSystem" />
                        <ToggleButton
                            Name="NavPipeline"
                            Aspect="$NavButton"
                            Content="07  FRAME PIPELINE"
                            Click="OnPipeline" />
                        <ToggleButton
                            Name="NavDiagnostics"
                            Aspect="$NavButton"
                            Content="08  DIAGNOSTICS"
                            Click="OnDiagnostics" />
                    </StackPanel>
                    <Border
                        Grid.Row="2"
                        BorderBrush="$LineBrush"
                        BorderThickness="0,1,0,0"
                        Padding="20,16,16,18">
                        <StackPanel>
                            <TextBlock
                                Text="FRAME CONTRACT"
                                FontFamily="Cascadia Mono SemiBold"
                                FontSize="10"
                                Foreground="$PinkBrush" />
                            <TextBlock
                                Text="Drain. Settle. Layout. Cache. Commit."
                                FontSize="12"
                                Foreground="$SlateBrush"
                                TextWrapping="Wrap"
                                Margin="0,7,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <Grid
                Grid.Column="1"
                ClipToBounds="True">
                <WelcomeChapterView
                    Name="PageWelcome"
                    Visibility="Collapsed" />
                <RetainedModelChapterView
                    Name="PageRetained"
                    Visibility="Collapsed" />
                <MarkupChapterView
                    Name="PageMarkup"
                    Visibility="Collapsed" />
                <AspectChapterView
                    Name="PageAspect"
                    Visibility="Collapsed" />
                <MotionChapterView
                    Name="PageMotion"
                    Visibility="Collapsed" />
                <SolarSystemChapterView
                    Name="PageSolarSystem"
                    Visibility="Collapsed" />
                <FramePipelineChapterView
                    Name="PagePipeline"
                    Visibility="Collapsed" />
                <DiagnosticsChapterView
                    Name="PageDiagnostics"
                    Visibility="Collapsed" />
            </Grid>
        </Grid>
        <Border
            Grid.Row="2"
            Background="$PanelAltBrush"
            BorderBrush="$LineBrush"
            BorderThickness="0,1,0,0"
            Padding="26,0,26,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="250" />
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Name="ChapterCounter"
                    Grid.Column="0"
                    Text="CHAPTER 01 / 08"
                    FontFamily="Cascadia Mono SemiBold"
                    FontSize="10"
                    Foreground="$SlateBrush"
                    VerticalAlignment="Center" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border
                        Width="42"
                        Height="3"
                        Background="$CyanBrush"
                        Margin="0,0,5,0" />
                    <Border
                        Width="42"
                        Height="3"
                        Background="$PinkBrush"
                        Margin="0,0,5,0" />
                    <Border
                        Width="42"
                        Height="3"
                        Background="$LimeBrush"
                        Margin="0,0,5,0" />
                    <Border
                        Width="42"
                        Height="3"
                        Background="$OrangeBrush" />
                </StackPanel>
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Button
                        Name="PreviousButton"
                        Aspect="$GhostButton"
                        Content="&lt;-  PREVIOUS"
                        Click="OnPrevious"
                        IsEnabled="False"
                        Margin="0,0,10,0" />
                    <Button
                        Name="NextButton"
                        Aspect="$LimeButton"
                        Content="NEXT  ->"
                        Click="OnNext" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
