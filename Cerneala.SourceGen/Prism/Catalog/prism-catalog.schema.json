{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cerneala.dev/schemas/prism-catalog.schema.json",
  "title": "Cerneala Prism catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "catalogVersion",
    "defaultColorProfile",
    "commonProperties",
    "entries"
  ],
  "properties": {
    "$schema": {
      "const": "prism-catalog.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "catalogVersion": {
      "type": "string",
      "minLength": 1
    },
    "defaultColorProfile": {
      "type": "string",
      "minLength": 1
    },
    "commonProperties": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "composition",
        "layer",
        "group",
        "backdrop",
        "mask",
        "filter",
        "style"
      ],
      "properties": {
        "composition": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "layer": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "group": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "backdrop": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "mask": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "filter": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "style": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "enum": [
            "boolean",
            "argb32",
            "finite-components",
            "catalog-symbol",
            "typed-resource",
            "finite",
            "range"
          ]
        },
        "minimum": {
          "type": [
            "number",
            "null"
          ]
        },
        "maximum": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "property": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "valueType",
        "required",
        "domain",
        "unit"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "valueType": {
          "enum": [
            "boolean",
            "integer",
            "number",
            "color",
            "vector",
            "symbol",
            "resource"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "domain": {
          "$ref": "#/$defs/domain"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "kernel",
        "test",
        "documentation"
      ],
      "properties": {
        "runtime": {
          "type": "string",
          "minLength": 1
        },
        "kernel": {
          "type": "string",
          "minLength": 1
        },
        "test": {
          "type": "string",
          "minLength": 1
        },
        "documentation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stableId",
        "id",
        "symbol",
        "kind",
        "category",
        "properties",
        "capabilities",
        "deterministic",
        "cacheable",
        "coverage"
      ],
      "properties": {
        "stableId": {
          "type": "integer",
          "minimum": 1
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*:[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
        },
        "symbol": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "kind": {
          "enum": [
            "filter",
            "style",
            "blend-mode",
            "color-profile",
            "sampling"
          ]
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deterministic": {
          "type": "boolean"
        },
        "cacheable": {
          "type": "boolean"
        },
        "coverage": {
          "$ref": "#/$defs/coverage"
        },
        "transferFunction": {
          "type": "string"
        },
        "gamut": {
          "type": "string"
        },
        "intendedUse": {
          "type": "string"
        }
      }
    }
  }
}
