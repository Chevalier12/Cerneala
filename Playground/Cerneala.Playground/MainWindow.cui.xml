<Window
    Title="Cerneala Playground"
    Width="800"
    Height="600"
    MinWidth="720"
    MinHeight="480"
    WindowStartupLocation="CenterScreen"
    FrameRendered="OnFrameRendered"
    Background="#FF101418"
    BorderBrush="#FF343C46"
    BorderThickness="1"
    Padding="0">
    <Window.Resources>
        <SolidColorBrush Name="SurfaceBrush" Color="#FF181E24" />
        <SolidColorBrush Name="SurfaceRaisedBrush" Color="#FF20272F" />
        <SolidColorBrush Name="DividerBrush" Color="#FF343C46" />
        <SolidColorBrush Name="TextBrush" Color="#FFF2F4F5" />
        <SolidColorBrush Name="MutedTextBrush" Color="#FFA9B1BA" />
        <SolidColorBrush Name="AccentBrush" Color="#FF3DD6A5" />
        <SolidColorBrush Name="AccentHoverBrush" Color="#FF174C42" />
        <SolidColorBrush Name="WarningBrush" Color="#FFFFC857" />

        <Aspect Target="TextBlock">
            @default
            {
                FontFamily = "Segoe UI";
                FontSize = 14;
                Foreground = $TextBrush;
            }
        </Aspect>

    </Window.Resources>

    <Grid Name="PlaygroundLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="$SurfaceRaisedBrush"
            BorderBrush="$DividerBrush"
            BorderThickness="0,0,0,1"
            Padding="20,14,20,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="Cerneala Playground"
                    FontFamily="Segoe UI Semibold"
                    FontSize="19" />

                <TextBlock
                    Name="SelectedShowcaseText"
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="Selecteaza un showcase"
                    Foreground="$AccentBrush"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center" />

                <TextBlock
                    Name="FrameDiagnosticsText"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Text="Astept primul frame..."
                    FontFamily="Consolas"
                    FontSize="11"
                    TextWrapping="Wrap"
                    Foreground="$WarningBrush"
                    Margin="0,8,0,0" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="$SurfaceBrush"
                BorderBrush="$DividerBrush"
                BorderThickness="0,0,1,0">
                <ShowcaseNavigation
                    Name="NavigationScrollViewer"
                    ShowcaseSelected="OnShowcaseSelected" />
            </Border>

            <Grid Name="ShowcaseHost" Grid.Column="1">
                <StackPanel
                    Name="EmptyState"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <TextBlock
                        Name="EmptyStateTitle"
                        Text="Alege ceva din stanga"
                        FontFamily="Segoe UI Semibold"
                        FontSize="24"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Name="EmptyStateDescription"
                        Text="Showcase-urile separate vor deveni vizibile in grid-ul asta."
                        Foreground="$MutedTextBrush"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
